      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst alertType = data.isCritical ? '🚨 CRITICAL STOCK ALERT' : '⚠️ LOW STOCK ALERT';\nconst urgency = data.isCritical ? 'IMMEDIATELY' : 'soon';\nconst fridayNote = data.isFriday ? '\\n📅 *Friday Alert*: Weekend demand predicted to be HIGH. Please restock before evening.' : '';\n\nconst ownerMsg = `${alertType}\\n\\n` +\n  `*${data.item}* needs restocking ${urgency}.\\n\\n` +\n  `📦 Current Stock: *${data.newStock} ${data.unit}*\\n` +\n  `📉 Minimum Required: *${data.effectiveThreshold} ${data.unit}*\\n` +\n  `👤 Reported by: ${data.fromName}${fridayNote}\\n\\n` +\n  `_Please arrange restocking._`;\n\nreturn [{ json: { ...data, ownerMsg } }];"
