    {
      "parameters": {
        "jsCode": "// Parse staff Telegram message: /used 5 ice OR /stock charcoal 10\nconst message = $input.first().json.message;\nconst text = message?.text || '';\nconst chatId = message?.chat?.id;\nconst fromId = message?.from?.id;\nconst fromName = message?.from?.first_name || 'Staff';\nconst timestamp = new Date().toISOString();\n\n// Normalize item aliases\nconst itemAliases = {\n  ice: 'Ice',\n  ices: 'Ice',\n  charcoal: 'Charcoal',\n  coal: 'Charcoal',\n  water: 'Drinking Water',\n  'drinking water': 'Drinking Water',\n  softdrink: 'Soft Drinks',\n  'soft drink': 'Soft Drinks',\n  'soft drinks': 'Soft Drinks',\n  soda: 'Soft Drinks'\n};\n\nlet command = '';\nlet itemRaw = '';\nlet quantity = 0;\nlet parsedItem = '';\nlet isValid = false;\n\n// Match /used <qty> <item>\nconst usedMatch = text.match(/^\\/used\\s+(\\d+)\\s+(.+)$/i);\n// Match /stock <item> <qty>\nconst stockMatch = text.match(/^\\/stock\\s+(.+?)\\s+(\\d+)$/i);\n\nif (usedMatch) {\n  command = 'used';\n  quantity = parseInt(usedMatch[1]);\n  itemRaw = usedMatch[2].trim().toLowerCase();\n  parsedItem = itemAliases[itemRaw] || (itemRaw.charAt(0).toUpperCase() + itemRaw.slice(1));\n  isValid = true;\n} else if (stockMatch) {\n  command = 'stock';\n  itemRaw = stockMatch[1].trim().toLowerCase();\n  quantity = parseInt(stockMatch[2]);\n  parsedItem = itemAliases[itemRaw] || (itemRaw.charAt(0).toUpperCase() + itemRaw.slice(1));\n  isValid = true;\n}\n\nreturn [{\n  json: {\n    isValid,\n    command,\n    item: parsedItem,\n    quantity,\n    chatId,\n    fromId,\n    fromName,\n    timestamp,\n    rawText: text\n  }\n}];"
      },
