    {
      "parameters": {
        "jsCode": "// Find the matching inventory row and compute new stock\nconst parsed = $('Parse Staff Message').first().json;\nconst rows = $input.all();\n\nconst item = parsed.item;\nconst command = parsed.command;\nconst qty = parsed.quantity;\n\nlet matchedRow = null;\nlet rowIndex = -1;\n\nfor (let i = 0; i < rows.length; i++) {\n  const r = rows[i].json;\n  if (r.Item && r.Item.trim().toLowerCase() === item.toLowerCase()) {\n    matchedRow = r;\n    rowIndex = i + 2; // Sheets row index (1 header + 1-based)\n    break;\n  }\n}\n\nif (!matchedRow) {\n  return [{\n    json: {\n      found: false,\n      item,\n      chatId: parsed.chatId,\n      fromName: parsed.fromName,\n      message: `⚠️ Item \"${item}\" not found in inventory. Please check the item name.`\n    }\n  }];\n}\n\nlet currentStock = parseInt(matchedRow['Current Stock'] || 0);\nconst minThreshold = parseInt(matchedRow['Min Threshold'] || 5);\nconst unit = matchedRow['Unit'] || 'units';\nlet newStock = currentStock;\n\nif (command === 'used') {\n  newStock = Math.max(0, currentStock - qty);\n} else if (command === 'stock') {\n  newStock = qty;\n}\n\n// Predictive Friday threshold: lower threshold by 30% on Fridays\nconst today = new Date();\nconst dayOfWeek = today.getDay(); // 0=Sun, 5=Fri\nconst isFriday = dayOfWeek === 5;\nconst effectiveThreshold = isFriday ? Math.ceil(minThreshold * 1.3) : minThreshold;\n\nconst isLowStock = newStock <= effectiveThreshold;\nconst isCritical = newStock <= Math.floor(effectiveThreshold * 0.5);\n\nreturn [{\n  json: {\n    found: true,\n    rowIndex,\n    item,\n    command,\n    previousStock: currentStock,\n    newStock,\n    qty,\n    unit,\n    minThreshold,\n    effectiveThreshold,\n    isLowStock,\n    isCritical,\n    isFriday,\n    chatId: parsed.chatId,\n    fromName: parsed.fromName,\n    fromId: parsed.fromId,\n    timestamp: parsed.timestamp\n  }\n}];"
      },
