    {
      "parameters": {
        "jsCode": "// Build the weekend shopping list from all inventory rows\nconst rows = $input.all();\nconst today = new Date();\nconst isFriday = today.getDay() === 5;\n\n// Friday threshold multiplier (pre-compute for tomorrow)\nconst thresholdMultiplier = 1.3;\n\nconst shoppingItems = [];\nconst allItems = [];\n\nfor (const row of rows) {\n  const r = row.json;\n  if (!r.Item) continue;\n\n  const currentStock = parseInt(r['Current Stock'] || 0);\n  const minThreshold = parseInt(r['Min Threshold'] || 5);\n  const weekendTarget = parseInt(r['Weekend Target'] || minThreshold * 3);\n  const unit = r['Unit'] || 'units';\n\n  // For Thursday report, use weekend threshold (higher)\n  const effectiveThreshold = Math.ceil(minThreshold * thresholdMultiplier);\n  const qtyNeeded = Math.max(0, weekendTarget - currentStock);\n\n  allItems.push({\n    item: r.Item,\n    currentStock,\n    minThreshold: effectiveThreshold,\n    weekendTarget,\n    unit,\n    qtyNeeded,\n    status: currentStock <= effectiveThreshold ? 'LOW' : 'OK'\n  });\n\n  if (qtyNeeded > 0 || currentStock <= effectiveThreshold) {\n    shoppingItems.push({ item: r.Item, qtyNeeded, currentStock, unit, weekendTarget });\n  }\n}\n\nlet shoppingListText = '';\nif (shoppingItems.length === 0) {\n  shoppingListText = '✅ All items are sufficiently stocked for the weekend!';\n} else {\n  shoppingListText = shoppingItems.map(s =>\n    `• ${s.qtyNeeded > 0 ? s.qtyNeeded : 'LOW'} ${s.unit} of *${s.item}*` +\n    ` _(Current: ${s.currentStock}, Target: ${s.weekendTarget})_`\n  ).join('\\n');\n}\n\nconst dateStr = today.toLocaleDateString('en-PH', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });\n\nconst ownerMessage = `📋 *WEEKEND PREP ALERT*\\n` +\n  `_${dateStr}_\\n\\n` +\n  `Based on current stock levels and predicted weekend demand, please arrange the following purchases:\\n\\n` +\n  `${shoppingListText}\\n\\n` +\n  `📊 *Full Inventory Status:*\\n` +\n  allItems.map(a => `${a.status === 'LOW' ? '🔴' : '🟢'} ${a.item}: ${a.currentStock} ${a.unit}`).join('\\n') +\n  `\\n\\n_Please reply ✅ to confirm you have seen this alert._`;\n\nreturn [{\n  json: {\n    ownerMessage,\n    shoppingItemCount: shoppingItems.length,\n    hasItems: shoppingItems.length > 0\n  }\n}];"
      },
