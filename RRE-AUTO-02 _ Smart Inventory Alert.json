    {
      "parameters": {
        "jsCode": "const data = $('Compute New Stock').first().json;\nlet emoji = '✅';\nlet statusMsg = 'Stock updated!';\n\nif (data.isCritical) {\n  emoji = '🚨';\n  statusMsg = 'CRITICAL LOW STOCK!';\n} else if (data.isLowStock) {\n  emoji = '⚠️';\n  statusMsg = 'Low stock warning!';\n}\n\nconst actionText = data.command === 'used'\n  ? `Used ${data.qty} ${data.unit}`\n  : `Set stock to ${data.newStock} ${data.unit}`;\n\nconst fridayNote = data.isFriday ? '\\n📅 *Friday Mode*: Threshold raised for weekend demand.' : '';\n\nconst staffMsg = `${emoji} *${data.item}* — ${statusMsg}\\n` +\n  `Action: ${actionText}\\n` +\n  `Previous: ${data.previousStock} | New: *${data.newStock} ${data.unit}*\\n` +\n  `Min Threshold: ${data.effectiveThreshold} ${data.unit}${fridayNote}`;\n\nreturn [{\n  json: {\n    ...data,\n    staffMsg,\n    needsOwnerAlert: data.isLowStock || data.isCritical\n  }\n}];"
      },
